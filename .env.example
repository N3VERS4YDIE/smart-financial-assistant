# SIIGO credentials
SIIGO_USERNAME=your-email@your-domain.com
SIIGO_ACCESS_KEY=your_access_key
SIIGO_PARTNER_ID=SandboxSiigoApi
SIIGO_BASE_URL=https://api.siigo.com

# LLM provider (OpenRouter by default)
OPENROUTER_API_KEY=your_openrouter_key
LLM_MODEL=openai/gpt-4.1-mini
LLM_BASE_URL=https://openrouter.ai/api/v1

# RAG configuration
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
QDRANT_PATH=.qdrant
QDRANT_COLLECTION=financial_knowledge
KNOWLEDGE_BASE_PATH=knowledge_base

# Report download/parsing safety controls
ALLOWED_REPORT_HOSTS=blob.core.windows.net,api.siigo.com
REPORT_DOWNLOAD_TIMEOUT=60
REPORT_MAX_SIZE_MB=50
